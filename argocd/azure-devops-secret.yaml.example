# Secret de acesso do ArgoCD ao Azure DevOps (credential template para a organização)
# Este é um arquivo de TEMPLATE. Crie azure-devops-secret.yaml com seus dados reais.
# O arquivo azure-devops-secret.yaml é ignorado pelo git — nunca commite credenciais reais.
#
# COMO USAR:
# 1. Copie este arquivo: cp argocd/azure-devops-secret.yaml.example argocd/azure-devops-secret.yaml
# 2. Substitua os valores <...> com seus dados reais
# 3. Aplique manualmente (antes do bootstrap): kubectl apply -f argocd/azure-devops-secret.yaml
#
# GERAR PAT NO AZURE DEVOPS:
# Organization Settings → Personal Access Tokens → New Token
# Scopes necessários: Code (Read)
#
# Com repo-creds, qualquer ApplicationSet que referencie uma URL dentro de
# https://dev.azure.com/<ORGANIZATION> herdará estas credenciais automaticamente —
# não é necessário criar secrets individuais por repositório.

apiVersion: v1
kind: Secret
metadata:
  name: azure-devops-creds
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repo-creds
type: Opaque
stringData:
  type: git
  url: https://dev.azure.com/<ORGANIZATION>
  username: <AZURE_DEVOPS_EMAIL>
  password: <AZURE_DEVOPS_PAT>
