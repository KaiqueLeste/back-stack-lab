# Secret para autenticação do ArgoCD com registry GHCR (OCI)
# Crie este arquivo localmente (não commitar em repositório) e aplique:
# kubectl apply -f argocd/ghcr-secret.yaml
#
# Gerar token GHCR (Personal Access Token):
# https://github.com/settings/tokens com `read:packages` e/ou `write:packages`.

apiVersion: v1
kind: Secret
metadata:
  name: ghcr-creds
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository
  type: Opaque
stringData:
  type: helm
  url: https://ghcr.io
  username: <GHCR_USERNAME>
  password: <GHCR_TOKEN>
