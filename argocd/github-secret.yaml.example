# Secret para autenticação do ArgoCD com GitHub
# Este é um arquivo de TEMPLATE. Crie um arquivo github-secret.yaml com seus dados reais.
# O arquivo github-secret.yaml deve ser adicionado ao .gitignore para não expor suas credenciais.
#
# COMO USAR:
# 1. Copie este arquivo: cp argocd/github-secret.yaml.example argocd/github-secret.yaml
# 2. Substitua <GITHUB_TOKEN> com seu token do GitHub
# 3. O arquivo github-secret.yaml será ignorado automaticamente pelo git
# 4. Aplique com: kubectl apply -f argocd/github-secret.yaml
#
# GERAR TOKEN GITHUB:
# Acesse: https://github.com/settings/tokens
# Crie um token com escopo: repo (repositório privado e público)

apiVersion: v1
kind: Secret
metadata:
  name: github-creds
  namespace: argocd
  labels:
    argocd.argoproj.io/secret-type: repository
type: Opaque
stringData:
  type: git
  url: https://github.com/KaiqueLeste/back-stack-lab.git
  password: <GITHUB_TOKEN>
  username: not-used
