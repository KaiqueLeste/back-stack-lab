# Secret com credenciais AWS para o Crossplane provider-aws-upbound
# Este é um arquivo de TEMPLATE. Crie o aws-credentials.yaml com suas credenciais reais.
# O arquivo aws-credentials.yaml é ignorado pelo git — nunca commite credenciais reais.
#
# COMO USAR:
# 1. Copie este arquivo: cp crossplane/aws-credentials.yaml.example crossplane/aws-credentials.yaml
# 2. Substitua os valores <...> pelas suas credenciais reais
# 3. Aplique manualmente (fora do GitOps): kubectl apply -f crossplane/aws-credentials.yaml
#
# ONDE OBTER AS CREDENCIAIS:
# - Crie um IAM User com permissões necessárias (S3, Lambda, IAM) no console AWS
# - Ou use uma IAM Role via IRSA se o cluster rodar na AWS (recomendado em produção)
# - Gere uma Access Key em: IAM → Users → <usuário> → Security credentials → Access keys

apiVersion: v1
kind: Secret
metadata:
  name: aws-credentials
  namespace: crossplane-system
type: Opaque
stringData:
  credentials: |
    [default]
    aws_access_key_id = <AWS_ACCESS_KEY_ID>
    aws_secret_access_key = <AWS_SECRET_ACCESS_KEY>
